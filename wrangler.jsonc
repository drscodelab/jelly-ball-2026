{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-06-16",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "jelly-ball-2026",
	"kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "jelly-ball-2026-session"
    }
  ],
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}